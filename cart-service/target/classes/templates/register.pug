extends layout

block content
  .auth-wrap
    .auth-card
      h1 Create Account
      form.auth-form(action="/register-page" method="post")
        .form-group
          label(for="username") Username
          input#username(type="text" name="username" placeholder="Choose a username" required autocomplete="username")
        .form-group
          label(for="email") Email
          input#email(type="email" name="email" placeholder="you@example.com" required autocomplete="email")
        .form-group
          label(for="password") Password
          input#password(type="password" name="password" placeholder="Min 6 characters" required autocomplete="new-password" minlength="6")
        button.btn-primary.btn-full(type="submit") Create Account
      p.auth-link Already have an account? #[a(href="/login-page") Sign in]
