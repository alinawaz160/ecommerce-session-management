extends layout

block content
  h1 Your Cart

  if cartCount > 0
    .cart-wrap
      table.cart-table
        thead
          tr
            th Product
            th Price
            th Quantity
            th Subtotal
            th
        tbody
          each item in cart.items
            tr
              td.product-col
                if item.imageUrl
                  img.cart-thumb(src=item.imageUrl alt=item.productName onerror="this.src='https://via.placeholder.com/60x60?text=Item'")
                span= item.productName
              td $#{item.price}
              td
                form.inline-form(action="/cart-page/update/" + item.productId method="post")
                  input.qty-input(type="number" name="quantity" value=item.quantity min="0" max="99")
                  button.btn-sm(type="submit") Update
              td $#{item.subtotal}
              td
                form(action="/cart-page/remove/" + item.productId method="post")
                  button.btn-danger-sm(type="submit") Remove

      .cart-summary
        .cart-total
          span Total:
          strong $#{cart.totalAmount}
        .cart-actions
          a.btn-secondary(href="/") Continue Shopping
          a.btn-primary(href="/checkout-page") Proceed to Checkout
  else
    .empty-cart
      p.empty-msg Your cart is empty.
      a.btn-primary(href="/") Start Shopping
